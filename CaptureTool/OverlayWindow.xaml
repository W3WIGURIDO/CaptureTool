<Window x:Class="CaptureTool.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CaptureTool"
        mc:Ignorable="d"
        Title="OverlayWindow" Topmost="True" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False" Width="200" Height="150"
        Focusable="False" ShowActivated="False"
        Closing="Window_Closing" Loaded="Window_Loaded">
    <!-- [変更] 最大化→コーナー配置方式に変更。外枠マージングリッドを廃止 -->
    <Grid x:Name="gridView" Loaded="GridView_Loaded">
        <Grid x:Name="imageGrid" Width="200" Height="150">
            <Rectangle Stroke="Black" Opacity="0.5" Fill="Black"/>
            <Viewbox>
                <Grid>
                    <Image x:Name="viewImage" Source="{Binding ImageSource,Mode=OneTime}"/>
                </Grid>
            </Viewbox>
        </Grid>
        <Grid HorizontalAlignment="Left" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Background="Black" Opacity="0.7"/>
            <TextBlock Text="{Binding OverlayText,Mode=OneTime}" FontWeight="Bold" Foreground="White"/>
        </Grid>
    </Grid>
</Window>