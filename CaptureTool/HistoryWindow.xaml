<Window x:Class="CaptureTool.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="キャプチャ履歴" Width="680" Height="480"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="historyListBox"
                 SelectionMode="Extended"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.IsVirtualizing="True"
                 MouseDoubleClick="HistoryListBox_MouseDoubleClick">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="128"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="72"/>
                        </Grid.ColumnDefinitions>

                        <!-- サムネイル / エラー表示 -->
                        <Border Width="120" Height="90" Background="#1A1A1A"
                                Margin="0,0,6,0" HorizontalAlignment="Left">
                            <Grid>
                                <Image Source="{Binding Thumbnail}" Stretch="Uniform"/>
                                <TextBlock x:Name="noFileLabel"
                                           Text="ファイルなし" Foreground="#FF6060"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Border>

                        <!-- ファイル情報 -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding FileName}"
                                       FontWeight="Bold" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding FilePath}"
                                       FontSize="10" Foreground="Gray"
                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- 取得日時・タブ番号 -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                    HorizontalAlignment="Right" Margin="4,0,0,0">
                            <TextBlock Text="{Binding CapturedAtText}" FontSize="11"/>
                            <TextBlock Text="{Binding TabLabel}"
                                       FontSize="11" Foreground="DimGray"/>
                        </StackPanel>

                        <!-- ファイルなし状態のスタイル -->
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FileExists}" Value="False">
                                        <Setter Property="Opacity" Value="0.45"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                    </Grid>

                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding FileExists}" Value="False">
                            <Setter TargetName="noFileLabel" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 操作ボタン行 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="3">
            <Button Content="画像を開く"   Width="90" Margin="0,0,5,0" Click="OpenImageButton_Click"/>
            <Button Content="フォルダを開く" Width="100" Margin="0,0,5,0" Click="OpenFolderButton_Click"/>
            <Button Content="改名"         Width="60" Margin="0,0,5,0" Click="RenameButton_Click"/>
            <Button Content="削除"         Width="60"                  Click="DeleteButton_Click"/>
            <TextBlock x:Name="countLabel" VerticalAlignment="Center" Margin="12,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>